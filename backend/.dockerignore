# File yang TIDAK boleh masuk ke Docker image.
# Image harus runtime-only; semua konfigurasi sensitif (APP_KEY,
# DB_PASSWORD) di-mount dari host via `env_file` di docker-compose.yml.
.env
.env.*
!.env.example
.git
.gitignore
.phpunit.result.cache
.phpunit.cache
.idea
.vscode
node_modules
public/storage
# storage/logs dan storage/framework/{cache,sessions,views} harus ADA
# di image — Laravel butuh folder ini untuk runtime (cache path,
# session write, compiled views). Folder kosong (cuma .gitignore)
# cukup — runtime akan create sub-folder sesuai kebutuhan.
storage/*.key
storage/pail
storage/app/public
tests
**/*.log
docker-compose.override.yml
# vendor/ di-generate di dalam image oleh Dockerfile (`composer install
# --no-dev`). COPY . . di Dockerfile akan overwrite vendor/ host (yang
# mungkin punya dev deps dari local `composer install`), jadi kita
# exclude dari build context.
vendor
# Laravel cache files — di-generate runtime dari container, bukan host.
# Host cache mungkin refer ke dev deps (pail, pao) yang tidak ada di
# production install. Biarkan container yang generate.
bootstrap/cache/*.php
!bootstrap/cache/.gitkeep